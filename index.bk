<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Be Unavoidable — No One Is Coming For You</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
<style>
* { margin:0; padding:0; box-sizing:border-box; }

:root {
  --bg-dark: #0e0e0e;
  --bg-darker: #161616;
  --text-primary: #ffffff;
  --text-secondary: #a0a0a0;
  --brand-blue: #0050a5;
  --accent-red: #d32f2f;
}

body {
  font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
  background: var(--bg-dark);
  color: var(--text-primary);
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
  overflow-x: hidden;
}

/* ─── NAVIGATION ─── */
  .beu-nav {
    position: fixed; top:0; left:0; width:100%; z-index:9999;
    padding: 24px 48px;
    display: flex; justify-content:space-between; align-items:center;
    background: rgba(14,14,14,0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(255,255,255,0.06);
    box-sizing: border-box;
  }
  
  @media (max-width:768px) {
    .beu-nav { padding:18px 24px; }
  }

  /* ─── HERO ─── */
  .beu-hero {
    min-height: 100vh;
    display: flex; flex-direction:column; align-items:center; justify-content:center;
    text-align:center;
    padding: 140px 24px 80px;
    background: var(--bg-dark);
    position: relative;
    overflow: hidden;
  }
  
  /* Background texture */
  .beu-hero::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background: 
      radial-gradient(circle at 20% 30%, rgba(0,80,165,0.08) 0%, transparent 50%),
      radial-gradient(circle at 80% 70%, rgba(211,47,47,0.05) 0%, transparent 50%);
    pointer-events: none;
  }
  
  .beu-hero-content {
    max-width: 1000px;
    position: relative;
    z-index: 1;
  }
  
  /* Eyebrow */
  .beu-eyebrow {
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--brand-blue);
    margin-bottom: 24px;
    opacity: 0;
    animation: fadeInUp 0.8s ease-out 0.2s forwards;
  }
  
  /* Headline */
  .beu-headline {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(3.5rem, 10vw, 7rem);
    line-height: 0.95;
    letter-spacing: -0.02em;
    margin-bottom: 32px;
    opacity: 0;
    animation: fadeInUp 0.8s ease-out 0.4s forwards;
  }
  
  .beu-headline-accent {
    color: var(--brand-blue);
    display: block;
  }
  
  /* Subheadline */
  .beu-subhead {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.25rem, 2.5vw, 2rem);
    line-height: 1.4;
    color: var(--text-secondary);
    font-style: italic;
    max-width: 700px;
    margin: 0 auto 48px;
    opacity: 0;
    animation: fadeInUp 0.8s ease-out 0.6s forwards;
  }
  
  /* Data Point */
  .beu-data-point {
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.08);
    border-left: 3px solid var(--accent-red);
    padding: 24px 32px;
    margin: 48px auto;
    max-width: 800px;
    text-align: left;
    opacity: 0;
    animation: fadeInUp 0.8s ease-out 0.8s forwards;
  }
  
  .beu-data-label {
    font-family: 'Inter', sans-serif;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--accent-red);
    margin-bottom: 8px;
  }
  
  .beu-data-stat {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 2.5rem;
    line-height: 1;
    color: var(--text-primary);
    margin-bottom: 12px;
  }
  
  .beu-data-text {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--text-secondary);
  }
  
  .beu-data-text strong {
    color: var(--text-primary);
    font-weight: 600;
  }
  
  /* CTA Group */
  .beu-cta-group {
    display: flex;
    gap: 16px;
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
    margin-top: 48px;
    opacity: 0;
    animation: fadeInUp 0.8s ease-out 1s forwards;
  }
  
  .beu-cta-primary {
    display: inline-block;
    padding: 18px 48px;
    background: var(--brand-blue);
    color: #ffffff;
    font-family: 'Inter', sans-serif;
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
    text-decoration: none;
    border: 2px solid var(--brand-blue);
    border-radius: 2px;
    transition: all 0.3s ease;
    cursor: pointer;
  }
  
  .beu-cta-primary:hover {
    background: transparent;
    color: var(--brand-blue);
    transform: translateY(-2px);
  }
  
  .beu-cta-secondary {
    display: inline-block;
    padding: 18px 48px;
    background: transparent;
    color: var(--text-secondary);
    font-family: 'Inter', sans-serif;
    font-size: 0.9rem;
    font-weight: 500;
    letter-spacing: 1px;
    text-transform: uppercase;
    text-decoration: none;
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 2px;
    transition: all 0.3s ease;
    cursor: pointer;
  }
  
  .beu-cta-secondary:hover {
    border-color: rgba(255,255,255,0.4);
    color: var(--text-primary);
  }
  
  /* Scroll Indicator */
  .beu-scroll-indicator {
    position: absolute;
    bottom: 40px;
    left: 50%;
    transform: translateX(-50%);
    opacity: 0;
    animation: fadeInUp 0.8s ease-out 1.2s forwards, float 3s ease-in-out infinite;
  }
  
  .beu-scroll-indicator svg {
    width: 24px;
    height: 24px;
    stroke: var(--text-secondary);
  }
  
  /* Animations */
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  @keyframes float {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(10px); }
  }
  
  /* Responsive */
  @media (max-width:768px) {
    .beu-hero {
      padding: 120px 20px 60px;
    }
    
    .beu-data-point {
      padding: 20px 24px;
      margin: 32px auto;
    }
    
    .beu-cta-group {
      flex-direction: column;
      width: 100%;
      max-width: 320px;
      margin-left: auto;
      margin-right: auto;
    }
    
    .beu-cta-primary,
    .beu-cta-secondary {
      width: 100%;
      text-align: center;
    }
  }

/* === section-02-data.html === */

  /* ─── SECTION 02: THE DATA ─── */
  .beu-section-02 {
    background: var(--bg-darker);
    padding: 120px 24px;
    position: relative;
  }
  
  .beu-section-02-container {
    max-width: 1200px;
    margin: 0 auto;
  }
  
  /* Section Header */
  .beu-section-header {
    text-align: center;
    margin-bottom: 80px;
  }
  
  .beu-section-eyebrow {
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--accent-red);
    margin-bottom: 16px;
  }
  
  .beu-section-headline {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(3rem, 8vw, 5rem);
    line-height: 1;
    letter-spacing: -0.02em;
    margin-bottom: 24px;
  }
  
  .beu-section-subhead {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.1rem, 2vw, 1.5rem);
    line-height: 1.5;
    color: var(--text-secondary);
    font-style: italic;
    max-width: 700px;
    margin: 0 auto;
  }
  
  /* Stats Grid */
  .beu-stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 32px;
    margin-bottom: 64px;
  }
  
  .beu-stat-card {
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.08);
    border-left: 3px solid var(--brand-blue);
    padding: 32px;
    transition: all 0.3s ease;
  }
  
  .beu-stat-card:hover {
    background: rgba(255,255,255,0.03);
    border-left-color: var(--accent-red);
    transform: translateY(-4px);
  }
  
  .beu-stat-label {
    font-family: 'Inter', sans-serif;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--brand-blue);
    margin-bottom: 12px;
  }
  
  .beu-stat-number {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 3.5rem;
    line-height: 1;
    color: var(--text-primary);
    margin-bottom: 16px;
  }
  
  .beu-stat-number-red {
    color: var(--accent-red);
  }
  
  .beu-stat-text {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--text-secondary);
  }
  
  .beu-stat-text strong {
    color: var(--text-primary);
    font-weight: 600;
  }
  
  /* Featured Quote */
  .beu-featured-quote {
    background: rgba(0,80,165,0.08);
    border: 1px solid rgba(0,80,165,0.2);
    border-left: 4px solid var(--brand-blue);
    padding: 48px;
    margin: 64px auto;
    max-width: 900px;
  }
  
  .beu-quote-text {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.25rem, 2.5vw, 1.75rem);
    line-height: 1.5;
    font-style: italic;
    color: var(--text-primary);
    margin-bottom: 24px;
  }
  
  .beu-quote-attribution {
    font-family: 'Inter', sans-serif;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--brand-blue);
    text-transform: uppercase;
    letter-spacing: 1px;
  }
  
  .beu-quote-context {
    font-family: 'Inter', sans-serif;
    font-size: 0.85rem;
    color: var(--text-secondary);
    margin-top: 8px;
  }
  
  /* Reality Check */
  .beu-reality-check {
    text-align: center;
    margin-top: 80px;
    padding: 48px 24px;
    background: rgba(211,47,47,0.05);
    border: 1px solid rgba(211,47,47,0.2);
  }
  
  .beu-reality-headline {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(2rem, 5vw, 3rem);
    line-height: 1.1;
    margin-bottom: 16px;
    color: var(--accent-red);
  }
  
  .beu-reality-text {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.1rem, 2vw, 1.5rem);
    line-height: 1.5;
    color: var(--text-secondary);
    font-style: italic;
    max-width: 800px;
    margin: 0 auto;
  }
  
  /* Responsive */
  @media (max-width:768px) {
    .beu-section-02 {
      padding: 80px 20px;
    }
    
    .beu-section-header {
      margin-bottom: 48px;
    }
    
    .beu-stats-grid {
      grid-template-columns: 1fr;
      gap: 24px;
    }
    
    .beu-stat-card {
      padding: 24px;
    }
    
    .beu-featured-quote {
      padding: 32px 24px;
      margin: 48px auto;
    }
    
    .beu-reality-check {
      margin-top: 48px;
      padding: 32px 20px;
    }
  }

/* === section-03-gap.html === */

  /* ─── SECTION 03: THE GAP ─── */
  .beu-section-03 {
    background: var(--bg-dark);
    padding: 120px 24px;
    position: relative;
  }
  
  .beu-section-03-container {
    max-width: 1100px;
    margin: 0 auto;
  }
  
  /* Section Header */
  .beu-section-header {
    text-align: center;
    margin-bottom: 80px;
  }
  
  .beu-section-eyebrow {
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--brand-blue);
    margin-bottom: 16px;
  }
  
  .beu-section-headline {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(3rem, 8vw, 5rem);
    line-height: 1;
    letter-spacing: -0.02em;
    margin-bottom: 24px;
  }
  
  .beu-section-subhead {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.1rem, 2vw, 1.5rem);
    line-height: 1.5;
    color: var(--text-secondary);
    font-style: italic;
    max-width: 800px;
    margin: 0 auto;
  }
  
  /* Options Grid */
  .beu-options-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 32px;
    margin-bottom: 64px;
  }
  
  .beu-option-card {
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.08);
    padding: 40px 32px;
    position: relative;
  }
  
  .beu-option-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 3px;
    background: var(--accent-red);
  }
  
  .beu-option-number {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1rem;
    color: var(--accent-red);
    letter-spacing: 2px;
    margin-bottom: 12px;
  }
  
  .beu-option-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 2rem;
    line-height: 1.1;
    margin-bottom: 16px;
    color: var(--text-primary);
  }
  
  .beu-option-desc {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--text-secondary);
    margin-bottom: 16px;
  }
  
  .beu-option-verdict {
    font-family: 'Inter', sans-serif;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--accent-red);
    text-transform: uppercase;
    letter-spacing: 1px;
    padding-top: 16px;
    border-top: 1px solid rgba(255,255,255,0.1);
  }
  
  /* The Question */
  .beu-the-question {
    background: rgba(0,80,165,0.08);
    border: 1px solid rgba(0,80,165,0.2);
    border-left: 4px solid var(--brand-blue);
    padding: 48px;
    margin: 64px auto;
    max-width: 900px;
    text-align: center;
  }
  
  .beu-question-label {
    font-family: 'Inter', sans-serif;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--brand-blue);
    margin-bottom: 20px;
  }
  
  .beu-question-text {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    line-height: 1.3;
    font-style: italic;
    color: var(--text-primary);
    margin-bottom: 24px;
  }
  
  .beu-question-answer {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(2.5rem, 5vw, 4rem);
    line-height: 1;
    color: var(--brand-blue);
    margin-bottom: 16px;
  }
  
  .beu-question-clarification {
    font-family: 'Inter', sans-serif;
    font-size: 1rem;
    line-height: 1.6;
    color: var(--text-secondary);
  }
  
  .beu-question-clarification strong {
    color: var(--text-primary);
    font-weight: 600;
  }
  
  /* Transition Statement */
  .beu-transition {
    text-align: center;
    margin-top: 64px;
    padding: 48px 24px;
  }
  
  .beu-transition-text {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.25rem, 2.5vw, 1.75rem);
    line-height: 1.5;
    color: var(--text-secondary);
    font-style: italic;
    max-width: 800px;
    margin: 0 auto 24px;
  }
  
  .beu-transition-emphasis {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.2;
    color: var(--text-primary);
  }
  
  .beu-transition-emphasis span {
    color: var(--brand-blue);
  }
  
  /* Responsive */
  @media (max-width:768px) {
    .beu-section-03 {
      padding: 80px 20px;
    }
    
    .beu-section-header {
      margin-bottom: 48px;
    }
    
    .beu-options-grid {
      grid-template-columns: 1fr;
      gap: 24px;
    }
    
    .beu-option-card {
      padding: 32px 24px;
    }
    
    .beu-the-question {
      padding: 32px 24px;
      margin: 48px auto;
    }
    
    .beu-transition {
      margin-top: 48px;
      padding: 32px 20px;
    }
  }

/* === section-04-lanes.html === */

  /* ─── SECTION 04: SALES SKILLS REFRAMED ─── */
  .beu-section-04 {
    background: var(--bg-darker);
    padding: 120px 24px;
    position: relative;
  }
  
  .beu-section-04-container {
    max-width: 1200px;
    margin: 0 auto;
  }
  
  /* Section Header */
  .beu-section-header {
    text-align: center;
    margin-bottom: 80px;
  }
  
  .beu-section-eyebrow {
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--brand-blue);
    margin-bottom: 16px;
  }
  
  .beu-section-headline {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(2.5rem, 7vw, 4.5rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: 32px;
    max-width: 1000px;
    margin-left: auto;
    margin-right: auto;
  }
  
  .beu-section-headline span {
    color: var(--brand-blue);
  }
  
  .beu-section-subhead {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.1rem, 2vw, 1.5rem);
    line-height: 1.5;
    color: var(--text-secondary);
    font-style: italic;
    max-width: 800px;
    margin: 0 auto;
  }
  
  /* Intro Text */
  .beu-intro-text {
    font-size: 1.1rem;
    line-height: 1.8;
    color: var(--text-secondary);
    max-width: 900px;
    margin: 0 auto 64px;
    text-align: center;
  }
  
  .beu-intro-text strong {
    color: var(--text-primary);
    font-weight: 600;
  }
  
  /* Lanes Container */
  .beu-lanes-container {
    margin: 80px 0;
  }
  
  .beu-lanes-intro {
    text-align: center;
    margin-bottom: 64px;
  }
  
  .beu-lanes-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(2rem, 5vw, 3.5rem);
    line-height: 1.1;
    margin-bottom: 16px;
  }
  
  .beu-lanes-subtitle {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1rem, 2vw, 1.25rem);
    line-height: 1.5;
    color: var(--text-secondary);
    font-style: italic;
  }
  
  /* Lanes Grid */
  .beu-lanes-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(400px, 1fr));
    gap: 48px;
    margin-bottom: 64px;
  }
  
  .beu-lane-card {
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.08);
    border-top: 4px solid var(--brand-blue);
    padding: 48px 40px;
  }
  
  .beu-lane-number {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1rem;
    color: var(--brand-blue);
    letter-spacing: 2px;
    margin-bottom: 16px;
  }
  
  .beu-lane-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 2.5rem;
    line-height: 1;
    margin-bottom: 24px;
    color: var(--text-primary);
  }
  
  .beu-lane-desc {
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--text-secondary);
    margin-bottom: 32px;
  }
  
  .beu-lane-desc strong {
    color: var(--text-primary);
    font-weight: 600;
  }
  
  .beu-lane-examples-title {
    font-family: 'Inter', sans-serif;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--brand-blue);
    margin-bottom: 16px;
  }
  
  .beu-lane-example {
    padding: 16px 0;
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }
  
  .beu-lane-example:last-child {
    border-bottom: none;
  }
  
  .beu-lane-example-title {
    font-family: 'Inter', sans-serif;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 6px;
  }
  
  .beu-lane-example-text {
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--text-secondary);
  }
  
  /* Key Insight */
  .beu-key-insight {
    background: rgba(0,80,165,0.08);
    border: 1px solid rgba(0,80,165,0.2);
    border-left: 4px solid var(--brand-blue);
    padding: 48px;
    margin: 64px auto;
    max-width: 900px;
    text-align: center;
  }
  
  .beu-insight-label {
    font-family: 'Inter', sans-serif;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--brand-blue);
    margin-bottom: 20px;
  }
  
  .beu-insight-text {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.25rem, 2.5vw, 1.75rem);
    line-height: 1.5;
    font-style: italic;
    color: var(--text-primary);
  }
  
  .beu-insight-text strong {
    color: var(--brand-blue);
    font-style: normal;
  }
  
  /* Responsive */
  @media (max-width:768px) {
    .beu-section-04 {
      padding: 80px 20px;
    }
    
    .beu-section-header {
      margin-bottom: 48px;
    }
    
    .beu-lanes-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    
    .beu-lane-card {
      padding: 32px 24px;
    }
    
    .beu-key-insight {
      padding: 32px 24px;
      margin: 48px auto;
    }
  }

/* === section-05-how-it-works.html === */

  /* ─── SECTION 05: HOW IT WORKS ─── */
  .beu-section-05 {
    background: var(--bg-dark);
    padding: 120px 24px;
    position: relative;
  }
  
  .beu-section-05-container {
    max-width: 1100px;
    margin: 0 auto;
  }
  
  /* Section Header */
  .beu-section-header {
    text-align: center;
    margin-bottom: 80px;
  }
  
  .beu-section-eyebrow {
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--brand-blue);
    margin-bottom: 16px;
  }
  
  .beu-section-headline {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(3rem, 8vw, 5rem);
    line-height: 1;
    letter-spacing: -0.02em;
    margin-bottom: 24px;
  }
  
  .beu-section-subhead {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.1rem, 2vw, 1.5rem);
    line-height: 1.5;
    color: var(--text-secondary);
    font-style: italic;
    max-width: 800px;
    margin: 0 auto;
  }
  
  /* Journey Flow */
  .beu-journey-flow {
    position: relative;
    margin: 80px 0;
  }
  
  /* Connector Line */
  .beu-journey-flow::before {
    content: '';
    position: absolute;
    left: 40px;
    top: 80px;
    bottom: 80px;
    width: 2px;
    background: linear-gradient(to bottom, 
      var(--brand-blue) 0%, 
      var(--brand-blue) 80%, 
      transparent 100%
    );
  }
  
  .beu-step {
    position: relative;
    margin-bottom: 64px;
    padding-left: 120px;
  }
  
  .beu-step:last-child {
    margin-bottom: 0;
  }
  
  /* Step Number */
  .beu-step-number {
    position: absolute;
    left: 0;
    top: 0;
    width: 80px;
    height: 80px;
    background: var(--brand-blue);
    border: 3px solid var(--bg-dark);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 2rem;
    color: #ffffff;
    z-index: 2;
  }
  
  /* Step Content */
  .beu-step-content {
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.08);
    border-left: 3px solid var(--brand-blue);
    padding: 32px;
  }
  
  .beu-step-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 2rem;
    line-height: 1.1;
    margin-bottom: 16px;
    color: var(--text-primary);
  }
  
  .beu-step-desc {
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--text-secondary);
    margin-bottom: 20px;
  }
  
  .beu-step-desc strong {
    color: var(--text-primary);
    font-weight: 600;
  }
  
  .beu-step-value {
    font-family: 'Inter', sans-serif;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--brand-blue);
    text-transform: uppercase;
    letter-spacing: 1px;
    padding-top: 16px;
    border-top: 1px solid rgba(255,255,255,0.08);
  }
  
  /* Key Principle */
  .beu-key-principle {
    background: rgba(0,80,165,0.08);
    border: 1px solid rgba(0,80,165,0.2);
    border-left: 4px solid var(--brand-blue);
    padding: 48px;
    margin: 80px auto 0;
    max-width: 900px;
    text-align: center;
  }
  
  .beu-principle-label {
    font-family: 'Inter', sans-serif;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--brand-blue);
    margin-bottom: 20px;
  }
  
  .beu-principle-text {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.25rem, 2.5vw, 1.75rem);
    line-height: 1.5;
    font-style: italic;
    color: var(--text-primary);
  }
  
  .beu-principle-text strong {
    color: var(--brand-blue);
    font-style: normal;
  }
  
  /* Responsive */
  @media (max-width:768px) {
    .beu-section-05 {
      padding: 80px 20px;
    }
    
    .beu-section-header {
      margin-bottom: 48px;
    }
    
    .beu-journey-flow::before {
      left: 20px;
    }
    
    .beu-step {
      padding-left: 80px;
      margin-bottom: 48px;
    }
    
    .beu-step-number {
      width: 60px;
      height: 60px;
      font-size: 1.5rem;
    }
    
    .beu-step-content {
      padding: 24px;
    }
    
    .beu-key-principle {
      padding: 32px 24px;
      margin-top: 48px;
    }
  }

/* === section-06-modules.html === */

  /* ─── SECTION 06: WHAT YOU LEARN ─── */
  .beu-section-06 {
    background: var(--bg-darker);
    padding: 120px 24px;
    position: relative;
  }
  
  .beu-section-06-container {
    max-width: 1200px;
    margin: 0 auto;
  }
  
  /* Section Header */
  .beu-section-header {
    text-align: center;
    margin-bottom: 80px;
  }
  
  .beu-section-eyebrow {
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--accent-red);
    margin-bottom: 16px;
  }
  
  .beu-section-headline {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(3rem, 8vw, 5rem);
    line-height: 1;
    letter-spacing: -0.02em;
    margin-bottom: 24px;
  }
  
  .beu-section-subhead {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.1rem, 2vw, 1.5rem);
    line-height: 1.5;
    color: var(--text-secondary);
    font-style: italic;
    max-width: 800px;
    margin: 0 auto;
  }
  
  /* Intro Statement */
  .beu-intro-statement {
    background: rgba(211,47,47,0.08);
    border: 1px solid rgba(211,47,47,0.2);
    border-left: 4px solid var(--accent-red);
    padding: 40px;
    margin: 0 auto 80px;
    max-width: 900px;
    text-align: center;
  }
  
  .beu-intro-text {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.25rem, 2.5vw, 1.75rem);
    line-height: 1.5;
    font-style: italic;
    color: var(--text-primary);
  }
  
  .beu-intro-text strong {
    color: var(--accent-red);
    font-style: normal;
  }
  
  /* Modules Grid */
  .beu-modules-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 32px;
    margin-bottom: 64px;
  }
  
  .beu-module-card {
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.08);
    padding: 32px;
    transition: all 0.3s ease;
    position: relative;
  }
  
  .beu-module-card::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    background: var(--brand-blue);
    transition: all 0.3s ease;
  }
  
  .beu-module-card:hover {
    background: rgba(255,255,255,0.04);
    transform: translateX(4px);
  }
  
  .beu-module-card:hover::before {
    background: var(--accent-red);
  }
  
  .beu-module-number {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 0.9rem;
    color: var(--brand-blue);
    letter-spacing: 2px;
    margin-bottom: 12px;
  }
  
  .beu-module-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.75rem;
    line-height: 1.2;
    margin-bottom: 16px;
    color: var(--text-primary);
  }
  
  .beu-module-desc {
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--text-secondary);
  }
  
  /* Credibility Statement */
  .beu-credibility {
    background: rgba(0,80,165,0.08);
    border: 1px solid rgba(0,80,165,0.2);
    border-left: 4px solid var(--brand-blue);
    padding: 48px;
    margin: 80px auto 0;
    max-width: 900px;
    text-align: center;
  }
  
  .beu-credibility-label {
    font-family: 'Inter', sans-serif;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--brand-blue);
    margin-bottom: 20px;
  }
  
  .beu-credibility-text {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.25rem, 2.5vw, 1.75rem);
    line-height: 1.5;
    font-style: italic;
    color: var(--text-primary);
  }
  
  .beu-credibility-text strong {
    color: var(--brand-blue);
    font-style: normal;
  }
  
  /* Responsive */
  @media (max-width:768px) {
    .beu-section-06 {
      padding: 80px 20px;
    }
    
    .beu-section-header {
      margin-bottom: 48px;
    }
    
    .beu-intro-statement {
      padding: 32px 24px;
      margin-bottom: 48px;
    }
    
    .beu-modules-grid {
      grid-template-columns: 1fr;
      gap: 24px;
    }
    
    .beu-module-card {
      padding: 24px;
    }
    
    .beu-credibility {
      padding: 32px 24px;
      margin-top: 48px;
    }
  }

/* === section-07-qualification.html === */

  /* ─── SECTION 07: WHO THIS IS FOR ─── */
  .beu-section-07 {
    background: var(--bg-dark);
    padding: 120px 24px;
    position: relative;
  }
  
  .beu-section-07-container {
    max-width: 1100px;
    margin: 0 auto;
  }
  
  /* Section Header */
  .beu-section-header {
    text-align: center;
    margin-bottom: 80px;
  }
  
  .beu-section-eyebrow {
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--brand-blue);
    margin-bottom: 16px;
  }
  
  .beu-section-headline {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(3rem, 8vw, 5rem);
    line-height: 1;
    letter-spacing: -0.02em;
    margin-bottom: 24px;
  }
  
  .beu-section-subhead {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.1rem, 2vw, 1.5rem);
    line-height: 1.5;
    color: var(--text-secondary);
    font-style: italic;
    max-width: 800px;
    margin: 0 auto;
  }
  
  /* Two Column Layout */
  .beu-qualification-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(400px, 1fr));
    gap: 48px;
    margin-bottom: 64px;
  }
  
  /* Good Fit Card */
  .beu-fit-card {
    background: rgba(0,80,165,0.08);
    border: 1px solid rgba(0,80,165,0.2);
    border-left: 4px solid var(--brand-blue);
    padding: 48px 40px;
  }
  
  .beu-fit-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 2.5rem;
    line-height: 1;
    margin-bottom: 24px;
    color: var(--brand-blue);
  }
  
  .beu-fit-list {
    list-style: none;
  }
  
  .beu-fit-item {
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--text-secondary);
    padding: 16px 0;
    padding-left: 32px;
    border-bottom: 1px solid rgba(255,255,255,0.05);
    position: relative;
  }
  
  .beu-fit-item:last-child {
    border-bottom: none;
  }
  
  .beu-fit-item::before {
    content: '✓';
    position: absolute;
    left: 0;
    top: 16px;
    color: var(--brand-blue);
    font-weight: bold;
    font-size: 1.2rem;
  }
  
  /* Not a Fit Card */
  .beu-not-fit-card {
    background: rgba(211,47,47,0.08);
    border: 1px solid rgba(211,47,47,0.2);
    border-left: 4px solid var(--accent-red);
    padding: 48px 40px;
  }
  
  .beu-not-fit-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 2.5rem;
    line-height: 1;
    margin-bottom: 24px;
    color: var(--accent-red);
  }
  
  .beu-not-fit-item {
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--text-secondary);
    padding: 16px 0;
    padding-left: 32px;
    border-bottom: 1px solid rgba(255,255,255,0.05);
    position: relative;
  }
  
  .beu-not-fit-item:last-child {
    border-bottom: none;
  }
  
  .beu-not-fit-item::before {
    content: '✗';
    position: absolute;
    left: 0;
    top: 16px;
    color: var(--accent-red);
    font-weight: bold;
    font-size: 1.2rem;
  }
  
  /* Honesty Statement */
  .beu-honesty-statement {
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.08);
    border-left: 3px solid var(--brand-blue);
    padding: 48px;
    margin: 64px auto 0;
    max-width: 900px;
    text-align: center;
  }
  
  .beu-honesty-text {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.25rem, 2.5vw, 1.75rem);
    line-height: 1.5;
    font-style: italic;
    color: var(--text-primary);
  }
  
  .beu-honesty-text strong {
    color: var(--brand-blue);
    font-style: normal;
  }
  
  /* Responsive */
  @media (max-width:768px) {
    .beu-section-07 {
      padding: 80px 20px;
    }
    
    .beu-section-header {
      margin-bottom: 48px;
    }
    
    .beu-qualification-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    
    .beu-fit-card,
    .beu-not-fit-card {
      padding: 32px 24px;
    }
    
    .beu-honesty-statement {
      padding: 32px 24px;
      margin-top: 48px;
    }
  }

/* === section-08-final-cta.html === */

  /* ─── SECTION 08: FINAL CTA ─── */
  .beu-section-08 {
    background: var(--bg-darker);
    padding: 120px 24px;
    position: relative;
    text-align: center;
  }
  
  /* Background Texture */
  .beu-section-08::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background: 
      radial-gradient(circle at 30% 40%, rgba(0,80,165,0.1) 0%, transparent 50%),
      radial-gradient(circle at 70% 60%, rgba(211,47,47,0.08) 0%, transparent 50%);
    pointer-events: none;
  }
  
  .beu-section-08-container {
    max-width: 900px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }
  
  /* Main Message */
  .beu-cta-eyebrow {
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--brand-blue);
    margin-bottom: 24px;
  }
  
  .beu-cta-headline {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(3rem, 8vw, 5.5rem);
    line-height: 1;
    letter-spacing: -0.02em;
    margin-bottom: 32px;
  }
  
  .beu-cta-subhead {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.25rem, 2.5vw, 2rem);
    line-height: 1.4;
    color: var(--text-secondary);
    font-style: italic;
    margin-bottom: 64px;
  }
  
  /* CTA Buttons */
  .beu-cta-button-group {
    display: flex;
    flex-direction: column;
    gap: 20px;
    align-items: center;
    margin-bottom: 64px;
  }
  
  .beu-cta-primary {
    display: inline-block;
    padding: 24px 64px;
    background: var(--brand-blue);
    color: #ffffff;
    font-family: 'Inter', sans-serif;
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    text-decoration: none;
    border: 2px solid var(--brand-blue);
    border-radius: 2px;
    transition: all 0.3s ease;
    cursor: pointer;
  }
  
  .beu-cta-primary:hover {
    background: transparent;
    color: var(--brand-blue);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0,80,165,0.3);
  }
  
  .beu-cta-ghost {
    display: inline-block;
    padding: 16px 48px;
    background: transparent;
    color: var(--text-secondary);
    font-family: 'Inter', sans-serif;
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 1px;
    text-transform: uppercase;
    text-decoration: none;
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 2px;
    transition: all 0.3s ease;
    cursor: pointer;
  }
  
  .beu-cta-ghost:hover {
    border-color: var(--accent-red);
    color: var(--accent-red);
  }
  
  /* Final Statement */
  .beu-final-statement {
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.08);
    border-top: 3px solid var(--brand-blue);
    padding: 48px 40px;
    margin-top: 80px;
  }
  
  .beu-final-quote {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.25rem, 2.5vw, 1.75rem);
    line-height: 1.5;
    font-style: italic;
    color: var(--text-primary);
    margin-bottom: 24px;
  }
  
  .beu-final-quote strong {
    color: var(--brand-blue);
    font-style: normal;
  }
  
  .beu-final-author {
    font-family: 'Inter', sans-serif;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--brand-blue);
    text-transform: uppercase;
    letter-spacing: 1px;
  }
  
  /* Responsive */
  @media (max-width:768px) {
    .beu-section-08 {
      padding: 80px 20px;
    }
    
    .beu-cta-button-group {
      width: 100%;
      max-width: 320px;
      margin-left: auto;
      margin-right: auto;
    }
    
    .beu-cta-primary,
    .beu-cta-ghost {
      width: 100%;
      text-align: center;
    }
    
    .beu-final-statement {
      padding: 32px 24px;
      margin-top: 48px;
    }
  }

/* === section-09-footer.html === */

  /* ─── SECTION 09: FOOTER ─── */
  .beu-footer {
    background: var(--bg-dark);
    border-top: 1px solid rgba(255,255,255,0.08);
    padding: 80px 24px 40px;
  }
  
  .beu-footer-container {
    max-width: 1200px;
    margin: 0 auto;
  }
  
  /* Footer Grid */
  .beu-footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 64px;
    margin-bottom: 64px;
  }
  
  /* Brand Column */
  .beu-footer-brand {
    max-width: 350px;
  }
  
  .beu-footer-logo {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 2rem;
    letter-spacing: 1px;
    color: var(--text-primary);
    margin-bottom: 16px;
  }
  
  .beu-footer-tagline {
    font-family: 'Playfair Display', serif;
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--text-secondary);
    font-style: italic;
    margin-bottom: 24px;
  }
  
  .beu-footer-description {
    font-size: 0.85rem;
    line-height: 1.7;
    color: var(--text-secondary);
  }
  
  /* Footer Links */
  .beu-footer-column {
  }
  
  .beu-footer-column-title {
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--brand-blue);
    margin-bottom: 20px;
  }
  
  .beu-footer-links {
    list-style: none;
  }
  
  .beu-footer-link {
    margin-bottom: 12px;
  }
  
  .beu-footer-link a {
    font-size: 0.9rem;
    color: var(--text-secondary);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  
  .beu-footer-link a:hover {
    color: var(--text-primary);
  }
  
  /* Footer Bottom */
  .beu-footer-bottom {
    padding-top: 32px;
    border-top: 1px solid rgba(255,255,255,0.08);
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 20px;
  }
  
  .beu-footer-copyright {
    font-size: 0.85rem;
    color: var(--text-secondary);
  }
  
  .beu-footer-legal {
    display: flex;
    gap: 24px;
  }
  
  .beu-footer-legal a {
    font-size: 0.85rem;
    color: var(--text-secondary);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  
  .beu-footer-legal a:hover {
    color: var(--text-primary);
  }
  
  /* Responsive */
  @media (max-width:992px) {
    .beu-footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 48px;
    }
    
    .beu-footer-brand {
      grid-column: 1 / -1;
    }
  }
  
  @media (max-width:768px) {
    .beu-footer {
      padding: 60px 20px 32px;
    }
    
    .beu-footer-grid {
      grid-template-columns: 1fr;
      gap: 40px;
